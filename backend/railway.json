{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python main.py",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "buildCommand": "pip install -r requirements.txt"
  },
  "builds": [
    {
      "name": "fastapi-backend",
      "buildCommand": "pip install -r requirements.txt",
      "startCommand": "python main.py",
      "rootDirectory": "./"
    }
  ],
  "build_and_deploy": {
    "web": {
      "preDeployHook": "alembic upgrade head"
    }
  }
}
