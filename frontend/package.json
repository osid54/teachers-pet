{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "start-backend-windows": "cd ../backend && venv\\Scripts\\activate.bat && uvicorn main:app --reload --port 5000",
    "start-backend-unix": "cd ../backend && source venv/bin/activate && uvicorn main:app --reload --port 5000",
    "dev-all": "concurrently \"npm run start-backend-windows\" \"npm run dev\"",
    "dev-all-unix": "concurrently \"npm run start-backend-unix\" \"npm run dev\""
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@tanstack/react-query": "^5.81.5",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "axios": "^1.10.0",
    "next": "^16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.5.2",
    "sass": "^1.89.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^0.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.0",
    "eslint": "^10.0.0",
    "eslint-config-next": "^0.2.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0"
  }
}
